{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(composer install)",
      "Bash(composer update)",
      "Bash(composer require *)",
      "Bash(composer dump-autoload)",
      "Bash(composer test)",
      "Bash(./vendor/bin/phpunit*)",
      "Bash(.\\phpunit.cmd*)",
      "Bash(git status)",
      "Bash(git diff*)",
      "Bash(git log*)",
      "Bash(git branch*)",
      "Bash(git checkout*)",
      "Bash(git add*)",
      "Bash(git commit*)",
      "Bash(git merge*)",
      "Bash(git push*)"
    ],
    "deny": [
      "Bash(rm -rf *)",
      "Read(vendor/**)",
      "Edit(vendor/**)",
      "Edit(composer.lock)"
    ]
  }
}
