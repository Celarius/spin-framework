{
  "application": {
    "global": {
      "maintenance": false,
      "timezone": "UTC"
    },
    "secret": "test-secret-key"
  },
  "session": {
    "cookie": "SID",
    "timeout": 3600,
    "driver": "apcu"
  },
  "logger": {
    "level": "debug",
    "driver": "php"
  },
  "caches": {
    "default": {
      "adapter": "apcu",
      "config": {}
    },
    "redis": {
      "adapter": "redis",
      "config": {
        "options": {
          "host": "${env:REDIS_HOST|127.0.0.1}",
          "port": "${env:REDIS_PORT|6379}"
        }
      }
    }
  },
  "factories": {
    "http": {
      "stream": {
        "class": "\\Spin\\Factories\\Http\\StreamFactory"
      }
    }
  },
  "hooks": [],
  "connections": {
    "mysql": {
      "driver": "mysql",
      "host": "${env:DB_HOST|127.0.0.1}",
      "port": 3306,
      "database": "${env:DB_NAME|spin_test}",
      "username": "${env:DB_USER|spin_user}",
      "password": "${env:DB_PASSWORD|spin_password}"
    },
    "postgres": {
      "driver": "pgsql",
      "host": "${env:POSTGRES_HOST|127.0.0.1}",
      "port": 5432,
      "database": "${env:POSTGRES_DB|spin_test}",
      "username": "${env:POSTGRES_USER|spin_user}",
      "password": "${env:POSTGRES_PASSWORD|spin_password}"
    },
    "sqlite": {
      "driver": "sqlite",
      "database": ":memory:"
    }
  }
}
